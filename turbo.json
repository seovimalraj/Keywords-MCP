{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "inputs": ["src/**", "api/**", "tsconfig.json", "package.json"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false
    },
    "type-check": {
      "inputs": ["src/**", "api/**", "tsconfig.json"]
    },
    "clean": {
      "cache": false
    }
  }
}
