# Keywords MCP – Environment Variables
# Copy this file to .env and fill in the values

# ─── Required for AI features only ───────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
# Free tier: 15 requests/minute, 1500 requests/day
# ── Gemini AI ─────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ── Static API key (alternative to OAuth) ─────────────────────────
# Bearer token for direct MCP clients (e.g. local Claude Desktop)
MCP_API_KEY=your_secret_api_key_here

# ── OAuth 2.0 (for ChatGPT Actions and web-based MCP clients) ─────
# Client ID and secret — you choose these values and enter them in ChatGPT
OAUTH_CLIENT_ID=keywords-mcp-client
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# Login credentials for the OAuth authorization page
OAUTH_USERNAME=admin
OAUTH_PASSWORD=your_oauth_login_password_here

# Access token lifetime in milliseconds (default: 24h)
OAUTH_TOKEN_TTL=86400000

# Comma-separated allowed redirect URIs (optional — defaults to any https:// URI)
# Example for ChatGPT: https://chatgpt.com/aip/g-XXXX/oauth/callback
# OAUTH_REDIRECT_URIS=https://chatgpt.com/aip/g-XXXX/oauth/callback

# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# Max request body size in bytes (default: 1MB)
MAX_BODY_BYTES=1048576

# Per-request timeout in milliseconds (default: 55s)
REQ_TIMEOUT_MS=55000

# Rate limit: max requests per minute per IP (default: 60)
RATE_LIMIT_RPM=60

# ─── All other features work with NO API keys ─────────────────────────────────
# Google Autocomplete    → free, no key
# Google Trends          → free, no key
# YouTube Autocomplete   → free, no key
# Amazon Suggestions     → free, no key
# Pinterest Suggestions  → free, no key
# Wikipedia API          → free, no key
