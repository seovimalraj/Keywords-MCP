# Keywords MCP – Environment Variables
# Copy this file to .env and fill in the values

# ─── Required for AI features only ───────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
# Free tier: 15 requests/minute, 1500 requests/day
# Get your Gemini API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Secret token to protect your MCP endpoint (choose any long random string)
# All requests must include: Authorization: Bearer <this value>
MCP_API_KEY=your_secret_api_key_here

# HTTP server port (Docker / self-hosted only)
PORT=3000

# ─── All other features work with NO API keys ─────────────────────────────────
# Google Autocomplete    → free, no key
# Google Trends          → free, no key
# YouTube Autocomplete   → free, no key
# Amazon Suggestions     → free, no key
# Pinterest Suggestions  → free, no key
# Wikipedia API          → free, no key
